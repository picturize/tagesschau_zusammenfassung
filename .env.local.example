# Environment Variables — copy this to .env.local and fill in your values

# ------ YouTube Data API v3 ------
# Create a key at https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ------ Google Gemini ------
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ------ Resend (Email) ------
# Replace re_xxxxxxxxx with your real API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=frommann.paul@gmail.com

# ------ Vercel KV ------
# These are auto-injected on Vercel. For local dev, copy from:
# Vercel Dashboard → Storage → your KV store → .env.local
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here

# ------ Cron Security ------
# Pick any long random string. Add it in Vercel Dashboard → Settings → Environment Variables too.
# Vercel automatically sends this as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your_secret_string_here
